{
  "name": "api-graph-visualizer",
  "displayName": "File Graph Visualizer",
  "description": "Interactive visualization of file dependency graphs",
  "version": "0.1.0",
  "publisher": "gauravbhushan",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onView:apiGraphVisualizer.fileDropTree",
    "onCommand:apiGraphVisualizer.open",
    "onCommand:apiGraphVisualizer.focusInGraph",
    "onCommand:apiGraphVisualizer.buildFromCurrentFile",
    "onCommand:apiGraphVisualizer.traceFromSelection",
    "onCommand:apiGraphVisualizer.revertTraceFromSelection",
    "onCommand:apiGraphVisualizer.buildFromResource",
    "onCommand:apiGraphVisualizer.pickFileForGraph",
    "onCommand:apiGraphVisualizer.loadImportRoute",
    "onCommand:apiGraphVisualizer.toggleFileGraphLlm",
    "onCommand:apiGraphVisualizer.softDeleteFromBuildFromFile",
    "onCommand:apiGraphVisualizer.hardDeleteFromBuildFromFile",
    "onCommand:apiGraphVisualizer.restoreFromBuildFromFile",
    "onCommand:apiGraphVisualizer.openBacktrackedGraphsFolder",
    "onCommand:apiGraphVisualizer.copyMcpServerConfig",
    "onCommand:apiGraphVisualizer.openMcpReadme"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apiGraphVisualizer.open",
        "title": "File Graph: Open Visualizer",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "apiGraphVisualizer.focusInGraph",
        "title": "Focus in File Graph",
        "icon": "$(search-focus)"
      },
      {
        "command": "apiGraphVisualizer.buildFromCurrentFile",
        "title": "Build Graph from File",
        "icon": "$(graph)"
      },
      {
        "command": "apiGraphVisualizer.traceFromSelection",
        "title": "Trace from here",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "apiGraphVisualizer.revertTraceFromSelection",
        "title": "Revert Trace Here",
        "icon": "$(discard)"
      },
      {
        "command": "apiGraphVisualizer.buildFromResource",
        "title": "File Graph: Build Import Graph",
        "icon": "$(graph)"
      },
      {
        "command": "apiGraphVisualizer.pickFileForGraph",
        "title": "File Graph: Browse File"
      },
      {
        "command": "apiGraphVisualizer.loadImportRoute",
        "title": "File Graph: Load Import"
      },
      {
        "command": "apiGraphVisualizer.toggleFileGraphLlm",
        "title": "File Graph: Toggle LLM"
      },
      {
        "command": "apiGraphVisualizer.softDeleteFromBuildFromFile",
        "title": "Soft Delete"
      },
      {
        "command": "apiGraphVisualizer.hardDeleteFromBuildFromFile",
        "title": "Hard Delete"
      },
      {
        "command": "apiGraphVisualizer.restoreFromBuildFromFile",
        "title": "Restore"
      },
      {
        "command": "apiGraphVisualizer.openBacktrackedGraphsFolder",
        "title": "File Graph: Open backtracked graphs folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "apiGraphVisualizer.copyMcpServerConfig",
        "title": "Explorer Map: Copy Cursor MCP config (md handler)"
      },
      {
        "command": "apiGraphVisualizer.openMcpReadme",
        "title": "Explorer Map: Open MCP server README"
      }
    ],
    "keybindings": [
      {
        "command": "apiGraphVisualizer.softDeleteFromBuildFromFile",
        "key": "ctrl+Delete",
        "mac": "cmd+Delete",
        "when": "view == apiGraphVisualizer.fileDropTree"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "apiGraphVisualizer.buildFromResource",
          "when": "resourceExtname == '.ts' || resourceExtname == '.tsx' || resourceExtname == '.js' || resourceExtname == '.jsx' || resourceExtname == '.mjs' || resourceExtname == '.cjs'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apiGraphVisualizer.buildFromResource",
          "when": "view == apiGraphVisualizer.fileDropTree && viewItem == workspaceFile && (resourceExtname == '.ts' || resourceExtname == '.tsx' || resourceExtname == '.js' || resourceExtname == '.jsx' || resourceExtname == '.mjs' || resourceExtname == '.cjs')",
          "group": "navigation"
        },
        {
          "command": "apiGraphVisualizer.softDeleteFromBuildFromFile",
          "when": "view == apiGraphVisualizer.fileDropTree && viewItem == workspaceFile",
          "group": "1_modification"
        },
        {
          "command": "apiGraphVisualizer.hardDeleteFromBuildFromFile",
          "when": "view == apiGraphVisualizer.fileDropTree && viewItem == workspaceFile",
          "group": "1_modification"
        },
        {
          "command": "apiGraphVisualizer.restoreFromBuildFromFile",
          "when": "view == apiGraphVisualizer.fileDropTree && viewItem == softDeletedFile",
          "group": "1_modification"
        },
        {
          "command": "apiGraphVisualizer.hardDeleteFromBuildFromFile",
          "when": "view == apiGraphVisualizer.fileDropTree && viewItem == softDeletedFile",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "apiGraphVisualizer.focusInGraph",
          "when": "editorTextFocus",
          "group": "2_editor"
        },
        {
          "command": "apiGraphVisualizer.buildFromCurrentFile",
          "when": "editorTextFocus",
          "group": "2_editor"
        },
        {
          "command": "apiGraphVisualizer.traceFromSelection",
          "when": "editorHasSelection && editorTextFocus",
          "group": "2_editor"
        }
      ],
      "editor/context": [
        {
          "command": "apiGraphVisualizer.traceFromSelection",
          "when": "editorHasSelection && editorTextFocus && (resourceExtname == '.ts' || resourceExtname == '.tsx' || resourceExtname == '.js' || resourceExtname == '.jsx' || resourceExtname == '.mjs' || resourceExtname == '.cjs')",
          "group": "navigation"
        },
        {
          "command": "apiGraphVisualizer.revertTraceFromSelection",
          "when": "editorTextFocus && (resourceExtname == '.ts' || resourceExtname == '.tsx' || resourceExtname == '.js' || resourceExtname == '.jsx' || resourceExtname == '.mjs' || resourceExtname == '.cjs')",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "apiGraphVisualizer.openBacktrackedGraphsFolder",
          "when": "view == apiGraphVisualizer.fileDropTree",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "api-graph-sidebar",
          "title": "Explorer Map",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "api-graph-sidebar": [
        {
          "type": "webview",
          "id": "apiGraphVisualizer.fileDropTree",
          "name": "Explorer Map"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "apiGraphVisualizer.explorerMapMd",
        "label": "Explorer Map (md notes MCP)"
      }
    ],
    "configuration": {
      "title": "Explorer Map",
      "properties": {
        "apiGraphVisualizer.autoOpenGraphOnActiveEditor": {
          "type": "boolean",
          "default": false,
          "description": "Deprecated: automatic graph opening from active editor is disabled; use Explorer Map tree actions."
        },
        "apiGraphVisualizer.mcp.showRunnerTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Show “Open MCP server in terminal” in Explorer Map → Features. Set false to hide (Cursor still runs MCP from its own config)."
        },
        "apiGraphVisualizer.mcp.nodeExecutable": {
          "type": "string",
          "default": "node",
          "description": "Node binary used in the copied Cursor MCP `command` field. If the Agent never lists `read_md_handler_file`, set this to the full path from `which node` (Cursor often does not load nvm from your shell)."
        },
        "apiGraphVisualizer.mcp.runInProjectTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Run the Explorer Map MCP process in a dedicated integrated terminal (cwd = this workspace). Recommended so each project uses its own folder and the server is not started as a hidden background process. Set false to use a headless process instead (same machine; still not shared across machines)."
        },
        "apiGraphVisualizer.mcp.writeGlobalMcp": {
          "type": "boolean",
          "default": false,
          "description": "Also write the MCP entry to ~/.cursor/mcp.json. Leave off so only this workspace’s .cursor/mcp.json registers the server (keeps the Agent/LLM tools scoped to that project). Turn on only if you need the same key in user-level config too."
        },
        "apiGraphVisualizer.mcp.autoReloadWindowOnToggle": {
          "type": "boolean",
          "default": true,
          "description": "After successfully toggling MCP on or off, reload the window automatically so Cursor picks up mcp.json changes. Set false to reload manually (Developer: Reload Window)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "typescript": "^5.3.0",
    "vis-data": "^7.1.9",
    "vis-network": "^9.1.9"
  }
}
